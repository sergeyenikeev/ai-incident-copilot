APP_NAME=ai-incident-copilot
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8080
APP_LOG_LEVEL=INFO

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_incident_copilot
POSTGRES_USER=incident
POSTGRES_PASSWORD=incident

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=ai-incident-worker
KAFKA_ENABLED=true
KAFKA_FAIL_FAST=false
KAFKA_CLIENT_ID=ai-incident-api
KAFKA_TOPIC_INCIDENT_CREATED=incident.created
KAFKA_TOPIC_ANALYSIS_REQUESTED=incident.analysis.requested
KAFKA_TOPIC_ANALYSIS_COMPLETED=incident.analysis.completed
KAFKA_MAX_RETRIES=3
WORKER_POLL_TIMEOUT_MS=1000
WORKER_RETRY_BACKOFF_SECONDS=1.5
WORKER_READY_FILE=/tmp/ai-incident-worker.ready

API_BASE_URL=http://localhost:8080
