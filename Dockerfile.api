FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy

WORKDIR /app

# Системные зависимости нужны для сборки Python-пакетов и работы с PostgreSQL.
RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential libpq-dev \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv==0.10.11

# Сначала копируем только файлы зависимостей и исходники приложения, чтобы
# сборка оставалась воспроизводимой и предсказуемой.
COPY pyproject.toml uv.lock README.md ./
COPY alembic.ini ./
COPY alembic ./alembic
COPY src ./src

RUN uv sync --frozen --no-dev

ENV PATH="/app/.venv/bin:${PATH}"

EXPOSE 8080

# В Docker Compose API сам применяет миграции перед стартом процесса.
# Для Kubernetes миграции вынесены в отдельный Job.
CMD ["sh", "-lc", "alembic upgrade head && ai-incident-api"]
